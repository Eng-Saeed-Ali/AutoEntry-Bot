# =============================================================================
# AutoEntry Bot — Environment Configuration Template
# =============================================================================
# Instructions:
#   1. Copy this file to `.env`:  cp .env.example .env
#   2. Fill in all values marked <REQUIRED> with your actual credentials.
#   3. Never commit `.env` to version control (it's in .gitignore).
# =============================================================================

# --- Telegram Bot ---
# Obtain from @BotFather on Telegram.
BOT_TOKEN=<REQUIRED - Your Telegram Bot API Token>

# --- Database (PostgreSQL) ---
# Connection URL format:
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# Docker Compose default: postgresql+asyncpg://autoentry:autoentry@localhost:5432/autoentry
DATABASE_URL=<REQUIRED - postgresql+asyncpg://user:pass@host:5432/dbname>

# Standalone PostgreSQL connection parts (used by Docker Compose & alembic):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autoentry
POSTGRES_USER=autoentry
POSTGRES_PASSWORD=autoentry

# --- Logging ---
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Telegram Polling ---
# Comma-separated list of update types to receive.
# Default covers messages and edited messages (covers document uploads).
TELEGRAM_ALLOWED_UPDATES=["message", "edited_message", "callback_query"]

# --- Future: Redis (for arq task queue, disabled by default) ---
# REDIS_URL=redis://localhost:6379/0